---
export interface Props {
  prevId: string;
  nextId: string;
  prevLabel?: string;
  nextLabel?: string;
  prevDisabled?: boolean;
}
const {
  prevId,
  nextId,
  prevLabel = 'Previous',
  nextLabel = 'Next',
  prevDisabled = true
} = Astro.props;
---

<nav class="gallery-nav">
  <button id={prevId} class:list={["nav-btn", { disabled: prevDisabled }]} aria-label={prevLabel}>
    &lt;
  </button>
  <button id={nextId} class="nav-btn" aria-label={nextLabel}>
    &gt;
  </button>
</nav>

<style>
  .gallery-nav {
    position: fixed;
    bottom: 1rem;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 1rem;
    pointer-events: none;
    z-index: 10;
  }

  .nav-btn {
    position: relative;
    background: none;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 2rem;
    font-weight: 200;
    color: var(--link-color);
    cursor: pointer;
    padding: 1rem;
    transition: color 0.2s;
    pointer-events: auto;
    touch-action: manipulation;
  }

  .nav-btn::before {
    content: '';
    position: fixed;
    width: 100px;
    top: 80px;
    bottom: 0;
    cursor: pointer;
  }

  .nav-btn:first-child::before {
    left: 0;
  }

  .nav-btn:last-child::before {
    right: 0;
  }

  .nav-btn:hover:not(.disabled) {
    color: var(--link-hover);
  }

  .nav-btn.disabled {
    color: var(--text-secondary);
    cursor: default;
    opacity: 0.5;
  }

  .nav-btn.disabled::before {
    cursor: default;
  }

  :global([data-theme="dark"]) .nav-btn.disabled {
    color: #444;
  }

  @media (max-width: 768px) {
    .gallery-nav {
      padding: 0 0.25rem;
    }

    .nav-btn {
      font-size: 1.8rem;
      padding: 0.75rem;
    }
  }
</style>
